---
import Base from '../../layouts/Base.astro';
import { getCounty, getDisastersByCounty, getNfipByCounty, fmtNumber, fmtDamage } from '../../lib/db';

const { slug } = Astro.params;
const db = (Astro.locals as any).runtime.env.DB;

const county = await getCounty(db, slug!);
if (!county) return Astro.redirect('/404');

const [disasters, nfip] = await Promise.all([
  getDisastersByCounty(db, county.fips),
  getNfipByCounty(db, county.fips),
]);

// Group disasters by type
const typeMap = new Map<string, number>();
for (const d of disasters) {
  typeMap.set(d.incident_type, (typeMap.get(d.incident_type) || 0) + 1);
}
const disasterTypeList = [...typeMap.entries()]
  .map(([type, count]) => ({ type, count }))
  .sort((a, b) => b.count - a.count);

const stateSlug = county.state_name?.toLowerCase().replace(/\s+/g, '-') || '';
---

<Base
  title={`${county.name}, ${county.state_code} — Disaster History`}
  description={`${county.name} County in ${county.state_name} has had ${fmtNumber(county.total_disasters)} FEMA disaster declarations. Top disaster type: ${county.top_incident_type || 'N/A'}. Data from ${county.first_disaster_year || '—'} to ${county.latest_disaster_year || '—'}.`}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Counties', href: '/counties/' },
    { name: county.state_name, href: `/state/${stateSlug}` },
    { name: county.name },
  ]}
>
  <section class="border-b border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-900/50">
    <div class="mx-auto max-w-7xl px-4 py-8 md:py-12">
      <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
        <a href="/" class="hover:underline">Home</a>
        <span>/</span>
        <a href="/counties/" class="hover:underline">Counties</a>
        <span>/</span>
        <a href={`/state/${stateSlug}`} class="hover:underline">{county.state_name}</a>
        <span>/</span>
        <span class="text-gray-900 dark:text-gray-100">{county.name}</span>
      </div>
      <h1 class="mt-4 text-3xl font-bold text-gray-900 dark:text-gray-100 md:text-4xl">{county.name}, {county.state_code}</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        FEMA disaster declaration history for {county.name} County, {county.state_name}.
      </p>

      <div class="mt-6 grid grid-cols-2 gap-4 md:grid-cols-4">
        <div class="rounded-lg bg-white p-4 ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800">
          <p class="text-xs text-gray-500 dark:text-gray-400">Total Disasters</p>
          <p class="mt-1 text-xl font-bold text-gray-900 dark:text-gray-100">{fmtNumber(county.total_disasters)}</p>
        </div>
        <div class="rounded-lg bg-white p-4 ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800">
          <p class="text-xs text-gray-500 dark:text-gray-400">Major Disasters</p>
          <p class="mt-1 text-xl font-bold text-gray-900 dark:text-gray-100">{fmtNumber(county.major_disasters)}</p>
        </div>
        <div class="rounded-lg bg-white p-4 ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800">
          <p class="text-xs text-gray-500 dark:text-gray-400">Top Hazard</p>
          <p class="mt-1 text-lg font-bold text-brand-600 dark:text-brand-400">{county.top_incident_type || '—'}</p>
        </div>
        <div class="rounded-lg bg-white p-4 ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800">
          <p class="text-xs text-gray-500 dark:text-gray-400">Data Range</p>
          <p class="mt-1 text-lg font-bold text-gray-900 dark:text-gray-100">{county.first_disaster_year || '—'}–{county.latest_disaster_year || '—'}</p>
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-4 py-8">
    <!-- Disaster Types -->
    {disasterTypeList.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Disaster Types</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {disasterTypeList.map(dt => (
            <div class="flex items-center justify-between rounded-lg bg-white p-4 ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800">
              <span class="text-sm font-medium text-gray-900 dark:text-gray-100">{dt.type}</span>
              <span class="text-lg font-bold text-brand-600 dark:text-brand-400">{fmtNumber(dt.count)}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Disaster Declarations -->
    {disasters.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Disaster Declarations</h2>
        <div class="mt-4 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200 dark:border-gray-700">
                <th class="px-3 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">DR#</th>
                <th class="px-3 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">Title</th>
                <th class="px-3 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">Type</th>
                <th class="px-3 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">Incident</th>
                <th class="px-3 py-3 text-left font-semibold text-gray-900 dark:text-gray-100">Date</th>
              </tr>
            </thead>
            <tbody>
              {disasters.map(d => (
                <tr class="border-b border-gray-100 hover:bg-gray-50 dark:border-gray-800 dark:hover:bg-gray-900/50">
                  <td class="px-3 py-3 font-mono text-xs text-gray-500 dark:text-gray-400">{d.disaster_number}</td>
                  <td class="px-3 py-3 font-medium text-gray-900 dark:text-gray-100">{d.title}</td>
                  <td class="px-3 py-3 text-xs text-gray-500 dark:text-gray-400">{d.declaration_type}</td>
                  <td class="px-3 py-3 text-xs text-gray-500 dark:text-gray-400">{d.incident_type}</td>
                  <td class="px-3 py-3 text-xs text-gray-500 dark:text-gray-400">{d.declaration_date?.split('T')[0] || '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- NFIP Flood Insurance Claims -->
    {nfip && nfip.claims > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">NFIP Flood Insurance Claims</h2>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          National Flood Insurance Program claims history for {county.name} County from FEMA NFIP data.
        </p>
        <div class="mt-4 grid grid-cols-2 gap-4 md:grid-cols-3">
          <div class="rounded-lg bg-white p-4 ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800">
            <p class="text-xs text-gray-500 dark:text-gray-400">Total Claims</p>
            <p class="mt-1 text-xl font-bold text-gray-900 dark:text-gray-100">{fmtNumber(nfip.claims)}</p>
          </div>
          <div class="rounded-lg bg-white p-4 ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800">
            <p class="text-xs text-gray-500 dark:text-gray-400">Total Paid</p>
            <p class="mt-1 text-xl font-bold text-brand-600 dark:text-brand-400">{fmtDamage(nfip.total_paid)}</p>
          </div>
          <div class="rounded-lg bg-white p-4 ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800">
            <p class="text-xs text-gray-500 dark:text-gray-400">Avg Per Claim</p>
            <p class="mt-1 text-xl font-bold text-gray-900 dark:text-gray-100">{fmtDamage(nfip.avg_paid)}</p>
          </div>
        </div>
        <p class="mt-3 text-xs text-gray-400 dark:text-gray-500">
          Source: FEMA National Flood Insurance Program (NFIP) OpenFEMA Claims Data.
        </p>
      </section>
    )}

    <!-- Related -->
    <section class="mb-8">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Related</h2>
      <div class="mt-3 flex flex-wrap gap-3">
        <a href={`/state/${stateSlug}`} class="rounded-lg bg-brand-50 px-4 py-2 text-sm font-medium text-brand-700 hover:bg-brand-100 dark:bg-brand-950 dark:text-brand-300 dark:hover:bg-brand-900">
          {county.state_name} State Profile
        </a>
        <a href="/counties/" class="rounded-lg bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700">
          All Counties
        </a>
      </div>
    </section>

    <p class="text-xs text-gray-400 dark:text-gray-500">
      Source: FEMA OpenFEMA Disaster Declarations Summaries v2. For informational purposes only.
    </p>
  </div>
</Base>
