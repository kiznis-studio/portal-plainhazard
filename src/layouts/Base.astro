---
import '../styles/global.css';
import Meta from '../components/seo/Meta.astro';
import Schema from '../components/seo/Schema.astro';
import Header from '../components/ui/Header.astro';
import Footer from '../components/ui/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  breadcrumbs?: Array<{ name: string; href?: string }>;
}

const props = Astro.props;
const siteName = "PlainHazard";
const fullTitle = props.title.includes(siteName) ? props.title : `${props.title} | ${siteName}`;
const breadcrumbSchema = (() => {
  const path = Astro.url.pathname.replace(/\/$/, '');
  if (path === '' || path === '/') return null;
  const items = props.breadcrumbs || [
    { name: 'Home', href: '/' },
    { name: props.title },
  ];
  return JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: items.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.name,
      ...(item.href ? { item: new URL(item.href, Astro.site).href } : {}),
    })),
  });
})();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ea580c" />

    <Meta
      title={fullTitle}
      description={props.description}
      image={props.image}
    />

    <Schema
      type="website"
      title={fullTitle}
      description={props.description}
      url={Astro.url.href}
      image={props.image}
      publisher={{ name: siteName }}
    />
    {breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}

    <script is:inline>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>

    <!-- Consent Mode v2 defaults — MUST come before any Google tags -->
    <script is:inline>
      window.dataLayer=window.dataLayer||[];
      function gtag(){dataLayer.push(arguments)}
      gtag('consent','default',{
        'ad_storage':'denied',
        'ad_user_data':'denied',
        'ad_personalization':'denied',
        'analytics_storage':'granted',
        'wait_for_update':500
      });
      gtag('consent','default',{
        'ad_storage':'granted',
        'ad_user_data':'granted',
        'ad_personalization':'granted',
        'analytics_storage':'granted',
        'region':['US']
      });
    </script>
    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PLACEHOLDER"></script>
    <script is:inline>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','G-PLACEHOLDER');</script>
    <!-- Umami -->
    <script defer src="https://analytics.opspixel.com/script.js" data-website-id="PLACEHOLDER"></script>
    <!-- AdSense -->
    <script defer src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7887321168925353" crossorigin="anonymous"></script>
  </head>

  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
